# fetchira config. Copy to fetchira.toml. Lives in the fetchira home dir
# ($FETCHIRA_HOME or ~/.config/fetchira), so it's found no matter where an MCP client launches the binary.
db_path = "usage.db"

# Full request/response debug log (the dashboard's Debug tab). On by default; bounded to the
# last `retention_hours` (and a fixed row + size cap). Set enabled = false to stop recording.
# [debug_log]
# enabled = true
# retention_hours = 24

# Optional: a Webshare proxy pool. Accounts with proxy = "pool" get a sticky proxy from it.
# [proxy_pool]
# webshare_url = "https://proxy.webshare.io/api/v2/proxy/list/download/<token>/-/any/username/direct/-/?plan_id=<id>"

# Optional: per-capability provider order (`fetchira priority`, or the dashboard's Routing
# priority panel). Listed providers are tried first, in this order; unlisted ones follow in
# the built-in order. Capabilities: search, read, deep_research, image.
# [priority]
# search = ["grok_web", "serper", "tavily"]
# deep_research = ["gemini_web", "parallel"]

# --- Key-based providers (api_key = literal or "env:VAR" resolved from .env) ---
[[account]]
provider = "serper"
label = "serper-1"
api_key = "env:SERPER_API_KEY"

[[account]]
provider = "tavily"
label = "tavily-1"
api_key = "env:TAVILY_API_KEY"
# proxy = "pool"

[[account]]
provider = "exa"
label = "exa-1"
api_key = "env:EXA_API_KEY"

[[account]]
provider = "firecrawl"
label = "firecrawl-1"
api_key = "env:FIRECRAWL_API_KEY"

[[account]]
provider = "parallel"
label = "parallel-1"
api_key = "env:PARALLEL_API_KEY"

[[account]]
provider = "steel"
label = "steel-1"
api_key = "env:STEEL_API_KEY"

# --- Web-session providers (no api_key). Run `fetchira login <provider>` once to capture cookies. ---
[[account]]
provider = "gemini_web"
label = "gemini-1"

[[account]]
provider = "grok_web"
label = "grok-1"
